AETHER_RPC_HTTP_URL=https://your-evm-rpc.example
# Optional backup RPCs
# AETHER_RPC_HTTP_URL_2=https://your-backup-rpc-2.example
# AETHER_RPC_HTTP_URL_3=https://your-backup-rpc-3.example

# Optional external PostgreSQL server.
# If omitted, Docker Compose uses the bundled PostgreSQL service.
# AETHER_DATABASE_URL=postgres://user:password@host:5432/aether_indexer

# Optional RPC rate-limit fallback delay. Provider-specific /second and /minute
# limit messages override this with 1s or 60s waits.
# AETHER_RPC_RATE_LIMIT_BACKOFF_MS=1000
